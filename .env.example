# Wave 1 local-only defaults. Never put a real API key in this file.
API_HOST=127.0.0.1
API_PORT=4310
MODEL_PROVIDER=OPENAI
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
MODEL_REQUEST_TIMEOUT_MS=30000
MODEL_MAX_INPUT_CHARACTERS=100000
MODEL_MAX_OUTPUT_TOKENS=2048
# Runtime-only Guided Learning BYOK secret; API and Worker read it independently.
WORKFLOW_BYOK_API_KEY=
# V1 defaults browser session-key registration off. Opt in only for local development.
ENABLE_BROWSER_SESSION_KEY=0
