{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-reading.local/contracts/wave0.v1.json",
  "title": "Wave 0 placeholder contracts",
  "type": "object",
  "required": ["schema_version", "health_response", "error_response"],
  "properties": {
    "schema_version": { "const": "wave0.v1" },
    "health_response": {
      "type": "object",
      "required": ["status", "service", "wave", "schema_version"],
      "properties": {
        "status": { "const": "ok" },
        "service": { "type": "string" },
        "wave": { "const": 0 },
        "schema_version": { "const": "wave0.v1" }
      },
      "additionalProperties": false
    },
    "error_response": {
      "type": "object",
      "required": ["error"],
      "properties": {
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
