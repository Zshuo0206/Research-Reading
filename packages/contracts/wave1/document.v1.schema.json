{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-reading.local/contracts/document.v1.json",
  "title": "Wave 1 document version",
  "type": "object",
  "required": ["schema_version", "document_version_id", "project_id", "source_sha256", "page_count", "extraction_profile", "pages"],
  "properties": {
    "schema_version": { "const": "document.v1" },
    "document_version_id": { "type": "string", "pattern": "^docv_[A-Za-z0-9_-]+$" },
    "project_id": { "type": "string", "pattern": "^proj_[A-Za-z0-9_-]+$" },
    "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "page_count": { "type": "integer", "minimum": 1, "maximum": 300 },
    "extraction_profile": { "$ref": "#/$defs/extraction_profile" },
    "pages": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/page" } }
  },
  "$defs": {
    "extraction_profile": {
      "type": "object",
      "required": ["name", "version", "offset_unit", "normalization", "whitespace", "hyphenation"],
      "properties": {
        "name": { "const": "pdfjs-text-v1" },
        "version": { "const": "1" },
        "pdfjs_version": { "type": "string" },
        "offset_unit": { "const": "unicode_code_point" },
        "normalization": { "const": "NFKC" },
        "whitespace": { "const": "LF_AND_ASCII_SPACE" },
        "hyphenation": { "const": "PRESERVE" }
      },
      "additionalProperties": false
    },
    "page": {
      "type": "object",
      "required": ["page_number", "canonical_page_text", "canonical_page_text_sha256", "code_point_length"],
      "properties": {
        "page_number": { "type": "integer", "minimum": 1 },
        "canonical_page_text": { "type": "string" },
        "canonical_page_text_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "code_point_length": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
