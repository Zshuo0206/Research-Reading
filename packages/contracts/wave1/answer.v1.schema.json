{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-reading.local/contracts/answer.v1.json",
  "title": "Wave 1 answer and revisions",
  "type": "object",
  "required": ["schema_version", "answer_id", "question_id", "current_revision", "revisions", "review_status", "verification_status"],
  "properties": {
    "schema_version": { "const": "answer.v1" },
    "answer_id": { "type": "string", "pattern": "^answer_[A-Za-z0-9_-]+$" },
    "question_id": { "type": "string", "pattern": "^question_[A-Za-z0-9_-]+$" },
    "current_revision": { "type": "string", "pattern": "^arev_[A-Za-z0-9_-]+$" },
    "revisions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/revision" } },
    "review_status": { "enum": ["DRAFT", "CONFIRMED", "REJECTED"] },
    "verification_status": { "enum": ["PENDING", "VERIFIED", "INVALID", "INSUFFICIENT_EVIDENCE"] }
  },
  "$defs": {
    "revision": {
      "type": "object",
      "required": ["revision_id", "revision_number", "created_by", "created_at", "content_hash", "claims"],
      "properties": {
        "revision_id": { "type": "string", "pattern": "^arev_[A-Za-z0-9_-]+$" },
        "revision_number": { "type": "integer", "minimum": 1 },
        "created_by": { "enum": ["MODEL", "LOCAL_OPERATOR"] },
        "created_at": { "type": "string", "format": "date-time" },
        "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "supersedes_revision_id": { "type": "string", "pattern": "^arev_[A-Za-z0-9_-]+$" },
        "claims": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/claim" } }
      },
      "additionalProperties": false
    },
    "claim": {
      "type": "object",
      "required": ["claim_id", "text", "claim_type", "evidence_refs"],
      "properties": {
        "claim_id": { "type": "string", "pattern": "^claim_[A-Za-z0-9_-]+$" },
        "text": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "claim_type": { "enum": ["PAPER_FACT", "AUTHOR_CLAIM", "AGENT_INFERENCE", "INSUFFICIENT_EVIDENCE"] },
        "evidence_refs": { "type": "array", "items": { "type": "string", "pattern": "^evidence_[A-Za-z0-9_-]+$" } }
      },
      "allOf": [
        {
          "if": { "properties": { "claim_type": { "const": "INSUFFICIENT_EVIDENCE" } } },
          "then": { "properties": { "evidence_refs": { "type": "array", "maxItems": 0 } } }
        },
        {
          "if": { "properties": { "claim_type": { "enum": ["PAPER_FACT", "AUTHOR_CLAIM", "AGENT_INFERENCE"] } } },
          "then": { "required": ["evidence_refs"], "properties": { "evidence_refs": { "type": "array", "minItems": 1 } } }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
