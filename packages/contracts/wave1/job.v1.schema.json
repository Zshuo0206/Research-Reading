{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-reading.local/contracts/job.v1.json",
  "title": "Wave 1 job",
  "type": "object",
  "required": ["schema_version", "job_id", "kind", "state", "attempt", "max_attempts", "created_at"],
  "properties": {
    "schema_version": { "const": "job.v1" },
    "job_id": { "type": "string", "pattern": "^job_[A-Za-z0-9_-]+$" },
    "kind": { "enum": ["DOCUMENT_IMPORT", "QUESTION_PLAN", "ANSWER_GENERATION"] },
    "state": { "enum": ["QUEUED", "RUNNING", "SUCCEEDED", "FAILED", "CANCEL_REQUESTED", "CANCELLED"] },
    "attempt": { "type": "integer", "minimum": 0 },
    "max_attempts": { "type": "integer", "minimum": 1, "maximum": 10 },
    "idempotency_key": { "type": "string", "minLength": 1, "maxLength": 200 },
    "worker_id": { "type": "string" },
    "lease_until": { "type": "string", "format": "date-time" },
    "next_run_at": { "type": "string", "format": "date-time" },
    "failure_class": { "enum": ["RETRYABLE", "NON_RETRYABLE"] },
    "created_at": { "type": "string", "format": "date-time" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
