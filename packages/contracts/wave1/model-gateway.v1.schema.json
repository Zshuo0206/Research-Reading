{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-reading.local/contracts/model-gateway.v1.json",
  "title": "Wave 1 ModelGateway request response contract",
  "oneOf": [
    { "$ref": "#/$defs/question_plan_byok_request" },
    { "$ref": "#/$defs/question_plan_mock_request" },
    { "$ref": "#/$defs/question_plan_response" },
    { "$ref": "#/$defs/answer_byok_request" },
    { "$ref": "#/$defs/answer_mock_request" },
    { "$ref": "#/$defs/answer_response" },
    { "$ref": "#/$defs/guided_directions_byok_request" },
    { "$ref": "#/$defs/guided_directions_mock_request" },
    { "$ref": "#/$defs/guided_directions_response" },
    { "$ref": "#/$defs/guided_questions_byok_request" },
    { "$ref": "#/$defs/guided_questions_mock_request" },
    { "$ref": "#/$defs/guided_questions_response" },
    { "$ref": "#/$defs/guided_feedback_byok_request" },
    { "$ref": "#/$defs/guided_feedback_mock_request" },
    { "$ref": "#/$defs/guided_feedback_response" },
    { "$ref": "#/$defs/guided_summary_byok_request" },
    { "$ref": "#/$defs/guided_summary_mock_request" },
    { "$ref": "#/$defs/guided_summary_response" },
    { "$ref": "#/$defs/connection_test_byok_request" },
    { "$ref": "#/$defs/connection_test_mock_request" },
    { "$ref": "#/$defs/connection_test_response" }
  ],
  "$defs": {
    "runtime_secret_ref": {
      "description": "Invocation-only reference to a runtime secret. It is never persisted and never contains a plaintext API key.",
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "name"],
          "properties": {
            "kind": { "const": "ENVIRONMENT" },
            "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,127}$" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "handle"],
          "properties": {
            "kind": { "const": "SESSION_MEMORY" },
            "handle": { "type": "string", "pattern": "^secret_session_[A-Za-z0-9_-]+$" }
          },
          "additionalProperties": false
        }
      ]
    },
    "provider": { "enum": ["OPENAI", "GEMINI", "GROQ", "OPENROUTER", "CUSTOM_OPENAI_COMPATIBLE", "MOCK"] },
    "byok_provider_config": {
      "type": "object",
      "required": ["provider", "base_url", "model", "request_timeout_ms", "max_input_characters", "max_output_tokens"],
      "properties": {
        "provider": { "enum": ["OPENAI", "GEMINI", "GROQ", "OPENROUTER", "CUSTOM_OPENAI_COMPATIBLE"] },
        "base_url": { "type": "string", "format": "uri", "pattern": "^https://[^?#]+$" },
        "model": { "type": "string", "minLength": 1, "maxLength": 200 },
        "request_timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 120000 },
        "max_input_characters": { "type": "integer", "minimum": 1, "maximum": 10000000 },
        "max_output_tokens": { "type": "integer", "minimum": 1, "maximum": 100000 }
      },
      "additionalProperties": false
    },
    "mock_provider_config": {
      "type": "object",
      "required": ["provider", "fixture_id"],
      "properties": {
        "provider": { "const": "MOCK" },
        "fixture_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]{1,100}$" }
      },
      "additionalProperties": false
    },
    "provider_config": {
      "oneOf": [
        { "$ref": "#/$defs/byok_provider_config" },
        { "$ref": "#/$defs/mock_provider_config" }
      ]
    },
    "document_metadata": {
      "type": "object",
      "required": ["document_version_id", "page_count"],
      "properties": {
        "document_version_id": { "type": "string", "pattern": "^docv_[A-Za-z0-9_-]+$" },
        "page_count": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "context_spans": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://research-reading.local/contracts/evidence.v1.json#/$defs/context_span" }
    },
    "question_plan_input": {
      "type": "object",
      "required": ["document_metadata", "document_language", "method_learning_mode", "context_spans"],
      "properties": {
        "document_metadata": { "$ref": "#/$defs/document_metadata" },
        "document_language": { "$ref": "https://research-reading.local/contracts/question-plan.v1.json#/$defs/document_language" },
        "method_learning_mode": { "const": "METHOD_LEARNING" },
        "context_spans": { "$ref": "#/$defs/context_spans" }
      },
      "additionalProperties": false
    },
    "question_plan_draft": {
      "type": "object",
      "required": ["document_language", "retrieval_queries", "retrieval_terms", "questions"],
      "properties": {
        "document_language": { "$ref": "https://research-reading.local/contracts/question-plan.v1.json#/$defs/document_language" },
        "retrieval_queries": { "$ref": "https://research-reading.local/contracts/question-plan.v1.json#/$defs/retrieval_queries" },
        "retrieval_terms": { "$ref": "https://research-reading.local/contracts/question-plan.v1.json#/$defs/retrieval_terms" },
        "questions": { "type": "array", "minItems": 1, "maxItems": 12, "items": { "$ref": "https://research-reading.local/contracts/question-plan.v1.json#/$defs/question_draft" } }
      },
      "additionalProperties": false
    },
    "answer_input": {
      "type": "object",
      "required": ["confirmed_question", "context_spans", "document_metadata"],
      "properties": {
        "confirmed_question": {
          "type": "object",
          "required": ["question_id", "revision_id", "text"],
          "properties": {
            "question_id": { "type": "string", "pattern": "^question_[A-Za-z0-9_-]+$" },
            "revision_id": { "type": "string", "pattern": "^qrev_[A-Za-z0-9_-]+$" },
            "text": { "$ref": "https://research-reading.local/contracts/question-plan.v1.json#/$defs/question_text" }
          },
          "additionalProperties": false
        },
        "context_spans": { "$ref": "#/$defs/context_spans" },
        "document_metadata": { "$ref": "#/$defs/document_metadata" }
      },
      "additionalProperties": false
    },
    "supported_claim_draft": {
      "type": "object",
      "required": ["text", "claim_type", "candidate_context_span_ids"],
      "properties": {
        "text": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "claim_type": { "enum": ["PAPER_FACT", "AUTHOR_CLAIM", "AGENT_INFERENCE"] },
        "candidate_context_span_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^context_[A-Za-z0-9_-]+$" }
        }
      },
      "additionalProperties": false
    },
    "insufficient_claim_draft": {
      "type": "object",
      "required": ["text", "claim_type", "candidate_context_span_ids"],
      "properties": {
        "text": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "claim_type": { "const": "INSUFFICIENT_EVIDENCE" },
        "candidate_context_span_ids": { "type": "array", "maxItems": 0 }
      },
      "additionalProperties": false
    },
    "answer_success_output": {
      "type": "object",
      "required": ["status", "claims"],
      "properties": {
        "status": { "const": "SUCCESS" },
        "claims": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/supported_claim_draft" } }
      },
      "additionalProperties": false
    },
    "answer_insufficient_output": {
      "type": "object",
      "required": ["status", "claims"],
      "properties": {
        "status": { "const": "INSUFFICIENT_EVIDENCE" },
        "claims": { "type": "array", "minItems": 1, "maxItems": 1, "items": { "$ref": "#/$defs/insufficient_claim_draft" } }
      },
      "additionalProperties": false
    },
    "answer_output": {
      "oneOf": [
        { "$ref": "#/$defs/answer_success_output" },
        { "$ref": "#/$defs/answer_insufficient_output" }
      ]
    },
    "guided_generation_input": {
      "type": "object",
      "required": ["learning_goal", "document_metadata", "context_spans"],
      "properties": {
        "learning_goal": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "document_metadata": { "$ref": "#/$defs/document_metadata" },
        "context_spans": { "$ref": "#/$defs/context_spans" },
        "selected_direction_id": { "type": "string", "maxLength": 200 },
        "selected_direction": { "type": "object", "required": ["direction_id", "title", "description", "selection_basis"], "properties": { "direction_id": { "type": "string", "maxLength": 200 }, "title": { "type": "string", "maxLength": 200 }, "description": { "type": "string", "maxLength": 1000 }, "selection_basis": { "type": "string", "maxLength": 1000 } }, "additionalProperties": false },
        "current_question": { "type": "string", "maxLength": 2000 },
        "current_question_order": { "type": "integer", "minimum": 1, "maximum": 100 },
        "user_answer": { "type": "string", "maxLength": 10000 },
        "previous_question_history": { "type": "array", "items": { "$ref": "#/$defs/question_history_item" } },
        "question_history": { "type": "array", "items": { "$ref": "#/$defs/question_history_item" } },
        "completed_question_orders": { "type": "array", "maxItems": 20, "items": { "type": "integer", "minimum": 1 } },
        "skipped_question_orders": { "type": "array", "maxItems": 20, "items": { "type": "integer", "minimum": 1 } }
      },
      "additionalProperties": false
    },
    "question_history_item": {
      "type": "object",
      "required": ["question_id", "question_order", "question", "status", "user_answer", "skipped", "feedback_summary", "feedback_omissions", "reference_answer"],
      "properties": {
        "question_id": { "type": "string", "maxLength": 200 },
        "question_order": { "type": "integer", "minimum": 1, "maximum": 100 },
        "question": { "type": "string", "maxLength": 2000 },
        "status": { "type": "string", "maxLength": 100 },
        "user_answer": { "type": ["string", "null"], "maxLength": 10000 },
        "skipped": { "type": "boolean" },
        "skip_reason": { "type": ["string", "null"], "maxLength": 200 },
        "feedback_summary": { "type": ["string", "null"], "maxLength": 2000 },
        "feedback_omissions": { "type": "array", "maxItems": 20, "items": { "type": "string", "maxLength": 500 } },
        "reference_answer": { "type": ["string", "null"], "maxLength": 5000 }
      },
      "additionalProperties": false
    },
    "guided_direction_output": {
      "type": "object",
      "required": ["directions"],
      "properties": { "directions": { "type": "array", "minItems": 2, "maxItems": 3, "items": { "type": "object", "required": ["title", "description", "selection_basis"], "properties": { "title": { "type": "string", "minLength": 1, "maxLength": 200 }, "description": { "type": "string", "minLength": 1, "maxLength": 1000 }, "selection_basis": { "type": "string", "minLength": 1, "maxLength": 1000 } }, "additionalProperties": false } } },
      "additionalProperties": false
    },
    "guided_question_output": {
      "type": "object",
      "required": ["questions"],
      "properties": { "questions": { "type": "array", "minItems": 3, "maxItems": 7, "items": { "type": "object", "required": ["text"], "properties": { "text": { "type": "string", "minLength": 1, "maxLength": 1000 } }, "additionalProperties": false } } },
      "additionalProperties": false
    },
    "guided_feedback_output": {
      "type": "object",
      "required": ["status", "summary", "omissions", "reference_answer", "claims"],
      "properties": {
        "status": { "enum": ["SUCCESS", "INSUFFICIENT_EVIDENCE"] },
        "summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "omissions": { "type": "array", "maxItems": 20, "items": { "type": "string", "maxLength": 500 } },
        "reference_answer": { "type": "string", "minLength": 1, "maxLength": 5000 },
        "claims": { "type": "array", "minItems": 1, "maxItems": 20, "items": { "type": "object", "required": ["text", "claim_type", "context_span_id", "evidence_quote_candidate"], "properties": { "text": { "type": "string", "minLength": 1, "maxLength": 2000 }, "claim_type": { "enum": ["PAPER_FACT", "AUTHOR_CLAIM", "AGENT_INFERENCE", "INSUFFICIENT_EVIDENCE"] }, "context_span_id": { "type": "string", "pattern": "^context_[A-Za-z0-9_-]+$" }, "evidence_quote_candidate": { "type": "string", "maxLength": 2000 } }, "additionalProperties": false } }
      },
      "additionalProperties": false
    },
    "guided_summary_output": {
      "type": "object",
      "required": ["key_mastery_points", "major_weak_points", "next_stage_hint"],
      "properties": { "key_mastery_points": { "type": "array", "minItems": 1, "maxItems": 20, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } }, "major_weak_points": { "type": "array", "maxItems": 20, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } }, "next_stage_hint": { "type": "string", "minLength": 1, "maxLength": 2000 } },
      "additionalProperties": false
    },
    "connection_test_input": {
      "type": "object",
      "required": ["probe"],
      "properties": { "probe": { "const": true } },
      "additionalProperties": false
    },
    "connection_test_success_output": {
      "type": "object",
      "required": ["success", "provider", "model"],
      "properties": {
        "success": { "const": true },
        "provider": { "$ref": "#/$defs/provider" },
        "model": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "connection_test_failure_output": {
      "type": "object",
      "required": ["success", "provider", "model", "error_category"],
      "properties": {
        "success": { "const": false },
        "provider": { "$ref": "#/$defs/provider" },
        "model": { "type": "string", "minLength": 1 },
        "error_category": { "enum": ["AUTHENTICATION", "RATE_LIMIT", "TIMEOUT", "INVALID_RESPONSE", "UNAVAILABLE", "UNKNOWN"] },
        "error_message": { "type": "string", "minLength": 1, "maxLength": 500 }
      },
      "additionalProperties": false
    },
    "connection_test_output": {
      "oneOf": [
        { "$ref": "#/$defs/connection_test_success_output" },
        { "$ref": "#/$defs/connection_test_failure_output" }
      ]
    },
    "question_plan_byok_request": {
      "type": "object",
      "required": ["schema_version", "message_kind", "operation", "provider_config", "runtime_secret_ref", "input"],
      "properties": {
        "schema_version": { "const": "model-gateway.v1" },
        "message_kind": { "const": "REQUEST" },
        "operation": { "const": "GENERATE_QUESTION_PLAN" },
        "provider_config": { "$ref": "#/$defs/byok_provider_config" },
        "runtime_secret_ref": { "$ref": "#/$defs/runtime_secret_ref" },
        "input": { "$ref": "#/$defs/question_plan_input" }
      },
      "additionalProperties": false
    },
    "question_plan_mock_request": {
      "type": "object",
      "required": ["schema_version", "message_kind", "operation", "provider_config", "input"],
      "properties": {
        "schema_version": { "const": "model-gateway.v1" },
        "message_kind": { "const": "REQUEST" },
        "operation": { "const": "GENERATE_QUESTION_PLAN" },
        "provider_config": { "$ref": "#/$defs/mock_provider_config" },
        "input": { "$ref": "#/$defs/question_plan_input" }
      },
      "additionalProperties": false
    },
    "question_plan_response": {
      "type": "object",
      "required": ["schema_version", "message_kind", "operation", "output"],
      "properties": {
        "schema_version": { "const": "model-gateway.v1" },
        "message_kind": { "const": "RESPONSE" },
        "operation": { "const": "GENERATE_QUESTION_PLAN" },
        "output": { "$ref": "#/$defs/question_plan_draft" }
      },
      "additionalProperties": false
    },
    "answer_byok_request": {
      "type": "object",
      "required": ["schema_version", "message_kind", "operation", "provider_config", "runtime_secret_ref", "input"],
      "properties": {
        "schema_version": { "const": "model-gateway.v1" },
        "message_kind": { "const": "REQUEST" },
        "operation": { "const": "GENERATE_ANSWER" },
        "provider_config": { "$ref": "#/$defs/byok_provider_config" },
        "runtime_secret_ref": { "$ref": "#/$defs/runtime_secret_ref" },
        "input": { "$ref": "#/$defs/answer_input" }
      },
      "additionalProperties": false
    },
    "answer_mock_request": {
      "type": "object",
      "required": ["schema_version", "message_kind", "operation", "provider_config", "input"],
      "properties": {
        "schema_version": { "const": "model-gateway.v1" },
        "message_kind": { "const": "REQUEST" },
        "operation": { "const": "GENERATE_ANSWER" },
        "provider_config": { "$ref": "#/$defs/mock_provider_config" },
        "input": { "$ref": "#/$defs/answer_input" }
      },
      "additionalProperties": false
    },
    "answer_response": {
      "type": "object",
      "required": ["schema_version", "message_kind", "operation", "output"],
      "properties": {
        "schema_version": { "const": "model-gateway.v1" },
        "message_kind": { "const": "RESPONSE" },
        "operation": { "const": "GENERATE_ANSWER" },
        "output": { "$ref": "#/$defs/answer_output" }
      },
      "additionalProperties": false
    },
    "guided_directions_byok_request": { "type": "object", "required": ["schema_version", "message_kind", "operation", "provider_config", "runtime_secret_ref", "input"], "properties": { "schema_version": { "const": "model-gateway.v1" }, "message_kind": { "const": "REQUEST" }, "operation": { "const": "GENERATE_GUIDED_DIRECTIONS" }, "provider_config": { "$ref": "#/$defs/byok_provider_config" }, "runtime_secret_ref": { "$ref": "#/$defs/runtime_secret_ref" }, "input": { "$ref": "#/$defs/guided_generation_input" } }, "additionalProperties": false },
    "guided_directions_mock_request": { "type": "object", "required": ["schema_version", "message_kind", "operation", "provider_config", "input"], "properties": { "schema_version": { "const": "model-gateway.v1" }, "message_kind": { "const": "REQUEST" }, "operation": { "const": "GENERATE_GUIDED_DIRECTIONS" }, "provider_config": { "$ref": "#/$defs/mock_provider_config" }, "input": { "$ref": "#/$defs/guided_generation_input" } }, "additionalProperties": false },
    "guided_directions_response": { "type": "object", "required": ["schema_version", "message_kind", "operation", "output"], "properties": { "schema_version": { "const": "model-gateway.v1" }, "message_kind": { "const": "RESPONSE" }, "operation": { "const": "GENERATE_GUIDED_DIRECTIONS" }, "output": { "$ref": "#/$defs/guided_direction_output" } }, "additionalProperties": false },
    "guided_questions_byok_request": { "type": "object", "required": ["schema_version", "message_kind", "operation", "provider_config", "runtime_secret_ref", "input"], "properties": { "schema_version": { "const": "model-gateway.v1" }, "message_kind": { "const": "REQUEST" }, "operation": { "const": "GENERATE_GUIDED_QUESTIONS" }, "provider_config": { "$ref": "#/$defs/byok_provider_config" }, "runtime_secret_ref": { "$ref": "#/$defs/runtime_secret_ref" }, "input": { "$ref": "#/$defs/guided_generation_input" } }, "additionalProperties": false },
    "guided_questions_mock_request": { "type": "object", "required": ["schema_version", "message_kind", "operation", "provider_config", "input"], "properties": { "schema_version": { "const": "model-gateway.v1" }, "message_kind": { "const": "REQUEST" }, "operation": { "const": "GENERATE_GUIDED_QUESTIONS" }, "provider_config": { "$ref": "#/$defs/mock_provider_config" }, "input": { "$ref": "#/$defs/guided_generation_input" } }, "additionalProperties": false },
    "guided_questions_response": { "type": "object", "required": ["schema_version", "message_kind", "operation", "output"], "properties": { "schema_version": { "const": "model-gateway.v1" }, "message_kind": { "const": "RESPONSE" }, "operation": { "const": "GENERATE_GUIDED_QUESTIONS" }, "output": { "$ref": "#/$defs/guided_question_output" } }, "additionalProperties": false },
    "guided_feedback_byok_request": { "type": "object", "required": ["schema_version", "message_kind", "operation", "provider_config", "runtime_secret_ref", "input"], "properties": { "schema_version": { "const": "model-gateway.v1" }, "message_kind": { "const": "REQUEST" }, "operation": { "const": "GENERATE_GUIDED_FEEDBACK" }, "provider_config": { "$ref": "#/$defs/byok_provider_config" }, "runtime_secret_ref": { "$ref": "#/$defs/runtime_secret_ref" }, "input": { "$ref": "#/$defs/guided_generation_input" } }, "additionalProperties": false },
    "guided_feedback_mock_request": { "type": "object", "required": ["schema_version", "message_kind", "operation", "provider_config", "input"], "properties": { "schema_version": { "const": "model-gateway.v1" }, "message_kind": { "const": "REQUEST" }, "operation": { "const": "GENERATE_GUIDED_FEEDBACK" }, "provider_config": { "$ref": "#/$defs/mock_provider_config" }, "input": { "$ref": "#/$defs/guided_generation_input" } }, "additionalProperties": false },
    "guided_feedback_response": { "type": "object", "required": ["schema_version", "message_kind", "operation", "output"], "properties": { "schema_version": { "const": "model-gateway.v1" }, "message_kind": { "const": "RESPONSE" }, "operation": { "const": "GENERATE_GUIDED_FEEDBACK" }, "output": { "$ref": "#/$defs/guided_feedback_output" } }, "additionalProperties": false },
    "guided_summary_byok_request": { "type": "object", "required": ["schema_version", "message_kind", "operation", "provider_config", "runtime_secret_ref", "input"], "properties": { "schema_version": { "const": "model-gateway.v1" }, "message_kind": { "const": "REQUEST" }, "operation": { "const": "GENERATE_GUIDED_STAGE_SUMMARY" }, "provider_config": { "$ref": "#/$defs/byok_provider_config" }, "runtime_secret_ref": { "$ref": "#/$defs/runtime_secret_ref" }, "input": { "$ref": "#/$defs/guided_generation_input" } }, "additionalProperties": false },
    "guided_summary_mock_request": { "type": "object", "required": ["schema_version", "message_kind", "operation", "provider_config", "input"], "properties": { "schema_version": { "const": "model-gateway.v1" }, "message_kind": { "const": "REQUEST" }, "operation": { "const": "GENERATE_GUIDED_STAGE_SUMMARY" }, "provider_config": { "$ref": "#/$defs/mock_provider_config" }, "input": { "$ref": "#/$defs/guided_generation_input" } }, "additionalProperties": false },
    "guided_summary_response": { "type": "object", "required": ["schema_version", "message_kind", "operation", "output"], "properties": { "schema_version": { "const": "model-gateway.v1" }, "message_kind": { "const": "RESPONSE" }, "operation": { "const": "GENERATE_GUIDED_STAGE_SUMMARY" }, "output": { "$ref": "#/$defs/guided_summary_output" } }, "additionalProperties": false },
    "connection_test_byok_request": {
      "type": "object",
      "required": ["schema_version", "message_kind", "operation", "provider_config", "runtime_secret_ref", "input"],
      "properties": {
        "schema_version": { "const": "model-gateway.v1" },
        "message_kind": { "const": "REQUEST" },
        "operation": { "const": "CONNECTION_TEST" },
        "provider_config": { "$ref": "#/$defs/byok_provider_config" },
        "runtime_secret_ref": { "$ref": "#/$defs/runtime_secret_ref" },
        "input": { "$ref": "#/$defs/connection_test_input" }
      },
      "additionalProperties": false
    },
    "connection_test_mock_request": {
      "type": "object",
      "required": ["schema_version", "message_kind", "operation", "provider_config", "input"],
      "properties": {
        "schema_version": { "const": "model-gateway.v1" },
        "message_kind": { "const": "REQUEST" },
        "operation": { "const": "CONNECTION_TEST" },
        "provider_config": { "$ref": "#/$defs/mock_provider_config" },
        "input": { "$ref": "#/$defs/connection_test_input" }
      },
      "additionalProperties": false
    },
    "connection_test_response": {
      "type": "object",
